# Chargement du modèle
# MODEL_ENV=test → chargement local via MODEL_PATH (joblib), pas besoin de MLflow ni S3
# MODEL_ENV=prod|staging → MLflow client, filtre sur tags env + status, nécessite S3
MODEL_ENV=prod
MODEL_STATUS=best

# MLflow (utilisé si MODEL_ENV != test)
MLFLOW_URI=https://gviel-mlflow37.hf.space/
MODEL_NAME=getaround_pricing

# Fichier local (utilisé si MODEL_ENV=test)
MODEL_PATH=../models/getaround_pricing_model.pkl

# Credentials AWS S3 (artifact store MLflow — requis si MODEL_ENV=prod|staging)
# Bucket : aws-s3-mlflow, région : eu-west-3
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=eu-west-3
